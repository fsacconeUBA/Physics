{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMFn7kLcuxncDULibY1uYkt"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["\n","# Celda 1: Importar librerías\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from scipy.spatial import cKDTree\n","from scipy.interpolate import griddata\n","import warnings\n","warnings.filterwarnings('ignore')  # Evita advertencias de log(0)\n","\n","# Celda 2: Función para generar puntos con Poisson Disk (algoritmo de Bridson)\n","def poisson_disk_samples(width=1.0, height=1.0, r=0.05, k=30):\n","    \"\"\"\n","    Genera puntos en [0,width] x [0,height] con distancia mínima r.\n","    Algoritmo de Bridson (fast Poisson disk sampling).\n","    \"\"\"\n","    # Tamaño de celda\n","    cell_size = r / np.sqrt(2)\n","    cols = int(np.ceil(width / cell_size))\n","    rows = int(np.ceil(height / cell_size))\n","\n","    # Cuadrícula para almacenar índices de puntos (-1 = vacía)\n","    grid = np.full((rows, cols), -1, dtype=int)\n","\n","    # Lista de puntos y cola de puntos activos\n","    points = []\n","    active = []\n","\n","    # Primer punto aleatorio\n","    x0 = np.random.uniform(0, width)\n","    y0 = np.random.uniform(0, height)\n","    points.append((x0, y0))\n","    active.append(0)\n","    col = int(x0 // cell_size)\n","    row = int(y0 // cell_size)\n","    grid[row, col] = 0\n","\n","    while active:\n","        # Elegir un punto activo al azar\n","        idx = np.random.choice(active)\n","        x, y = points[idx]\n","        found = False\n","\n","        # Intentar generar k candidatos alrededor del punto\n","        for _ in range(k):\n","            # Ángulo aleatorio y radio entre r y 2r\n","            angle = 2 * np.pi * np.random.random()\n","            radius = r * (1 + np.random.random())  # [r, 2r]\n","            new_x = x + radius * np.cos(angle)\n","            new_y = y + radius * np.sin(angle)\n","\n","            # Verificar límites\n","            if new_x < 0 or new_x >= width or new_y < 0 or new_y >= height:\n","                continue\n","\n","            # Celda del candidato\n","            ncol = int(new_x // cell_size)\n","            nrow = int(new_y // cell_size)\n","\n","            # Revisar celdas vecinas (3x3) para ver si hay algún punto demasiado cerca\n","            too_close = False\n","            for i in range(max(0, nrow-1), min(rows, nrow+2)):\n","                for j in range(max(0, ncol-1), min(cols, ncol+2)):\n","                    if grid[i, j] != -1:\n","                        px, py = points[grid[i, j]]\n","                        if (new_x - px)**2 + (new_y - py)**2 < r**2:\n","                            too_close = True\n","                            break\n","                if too_close:\n","                    break\n","\n","            if not too_close:\n","                # Aceptar nuevo punto\n","                points.append((new_x, new_y))\n","                active.append(len(points)-1)\n","                grid[nrow, ncol] = len(points)-1\n","                found = True\n","                break\n","\n","        if not found:\n","            # Si no se encontró candidato, eliminar el punto de los activos\n","            active.remove(idx)\n","\n","    return np.array(points)\n","\n","# Celda 3: Parámetros de la simulación\n","np.random.seed(84)          # Para reproducibilidad\n","domain_size = 1.0            # Dominio cuadrado de lado 1\n","r_min = 0.05                 # Distancia mínima entre núcleos (Poisson Disk)\n","n_nucleos = 300               # Número aproximado (el algoritmo genera el que pueda)\n","v = 0.065     # Velocidad de crecimiento (constante)\n","D=0.05\n","\n","# Generar núcleos con Poisson Disk\n","print(\"Generando núcleos con Poisson Disk...\")\n","nucleos = poisson_disk_samples(width=domain_size, height=domain_size, r=r_min)\n","print(f\"Se generaron {len(nucleos)} núcleos.\")\n","\n","# Si quieres forzar un número exacto, puedes ajustar r_min iterativamente,\n","# pero para este ejemplo lo dejamos así.\n","\n","# Celda 4: Crear grid de puntos para evaluar la transformación\n","grid_size = 500              # Resolución del grid (500x500)\n","x = np.linspace(0, domain_size, grid_size)\n","y = np.linspace(0, domain_size, grid_size)\n","X, Y = np.meshgrid(x, y)\n","coords = np.vstack([X.ravel(), Y.ravel()]).T\n","\n","# Calcular distancia al núcleo más cercano usando k-d tree\n","tree = cKDTree(nucleos)\n","distancias, _ = tree.query(coords)\n","distancias = distancias.reshape(X.shape)\n","\n","# Celda 5: Evaluar fracción transformada en distintos tiempos\n","# Elegir tiempos logarítmicos desde 0.01 hasta el tiempo que cubra casi todo el dominio\n","t_max = 0.5 * np.sqrt(2)     # La diagonal máxima es sqrt(2), la mitad es un buen límite\n","tiempos = np.logspace(np.log10(0.01), np.log10(t_max), 50)\n","\n","fraccion = []\n","for t in tiempos:\n","    #transformada = distancias <= v * t\n","    transformada = distancias <= D * np.sqrt(t)\n","    Xt = np.mean(transformada)   # fracción transformada\n","    fraccion.append(Xt)\n","\n","fraccion = np.array(fraccion)\n","\n","# Celda 6: Graficar fracción transformada vs tiempo\n","plt.figure(figsize=(8,5))\n","plt.plot(tiempos, fraccion, 'o-', markersize=4)\n","plt.xlabel('Tiempo (t)')\n","plt.ylabel('Fracción transformada (X)')\n","plt.title('Cinética de transformación')\n","plt.grid(True)\n","plt.show()\n","\n","# Celda 7: Preparar datos para el gráfico de Avrami\n","# Evitar valores extremos donde ln(1-X) sea problemático\n","mask = (fraccion > 0.02) & (fraccion < 0.98)\n","t_fit = tiempos[mask]\n","X_fit = fraccion[mask]\n","\n","# Calcular y = ln(-ln(1-X)) y x = ln(t)\n","y_avrami = np.log(-np.log(1 - X_fit))\n","x_avrami = np.log(t_fit)\n","\n","# Ajuste lineal\n","coefs = np.polyfit(x_avrami, y_avrami, 1)\n","n = coefs[0]\n","b = coefs[1]\n","k = np.exp(b / n)\n","\n","print(f\"\\n--- Resultados del ajuste ---\")\n","print(f\"n = {n:.4f}\")\n","print(f\"k = {k:.4f} (unidades de tiempo^{-n})\")\n","print(f\"Ecuación: ln(-ln(1-X)) = {n:.4f} * ln(t) + {b:.4f}\")\n","\n","# Celda 8: Graficar curva de Avrami y recta ajustada\n","plt.figure(figsize=(8,5))\n","plt.plot(x_avrami, y_avrami, 'o', label='Datos simulados')\n","x_line = np.linspace(x_avrami.min(), x_avrami.max(), 100)\n","plt.plot(x_line, coefs[0]*x_line + coefs[1], 'r-', label='Ajuste lineal')\n","plt.xlabel('ln(t)')\n","plt.ylabel('ln(-ln(1-X))')\n","plt.title('Gráfico de Avrami')\n","plt.legend()\n","plt.grid(True)\n","plt.show()\n","\n","# Celda 9: Visualización de la teselación de Voronoi (opcional)\n","from scipy.spatial import Voronoi, voronoi_plot_2d\n","\n","plt.figure(figsize=(6,6))\n","vor = Voronoi(nucleos)\n","voronoi_plot_2d(vor, ax=plt.gca(), show_vertices=False, line_colors='k', line_width=0.5)\n","# Dibujar círculos para un tiempo específico, por ejemplo t = 0.1\n","t_ejemplo = t_max\n","#radio = v * t_ejemplo\n","radio = D * np.sqrt(t_ejemplo)\n","for (x0, y0) in nucleos:\n","    circle = plt.Circle((x0, y0), radio, color='r', fill=False, alpha=0.3)\n","    plt.gca().add_patch(circle)\n","plt.xlim(0, domain_size)\n","plt.ylim(0, domain_size)\n","plt.title(f'Núcleos y círculos en t={t_ejemplo}')\n","plt.gca().set_aspect('equal')\n","plt.show()\n","\n","# Celda 10: Comparación con la teoría KJMA para nucleación aleatoria\n","# Densidad de núcleos\n","rho = len(nucleos) / (domain_size**2)\n","# Para nucleación instantánea y crecimiento 2D, la teoría predice: X(t) = 1 - exp(-π ρ v^2 t^2)\n","# Es decir, n=2 y k = sqrt(π ρ) * v   (pero cuidado: en la ecuación estándar, -ln(1-X) = (kt)^n)\n","# Aquí (kt)^2 = π ρ v^2 t^2 => k = v * sqrt(π ρ)\n","k_teorico = v * np.sqrt(np.pi * rho)\n","#k_teorico = D * np.sqrt(np.pi * rho*t_ejemplo)\n","n_teorico = 2.0\n","\n","print(f\"\\n--- Comparación con KJMA teórica (nucleación aleatoria) ---\")\n","print(f\"n teórico = {n_teorico}\")\n","print(f\"k teórico = {k_teorico:.4f}\")\n","print(f\"Diferencia relativa en n: {abs(n - n_teorico)/n_teorico*100:.2f}%\")\n","print(f\"Diferencia relativa en k: {abs(k - k_teorico)/k_teorico*100:.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":779},"id":"RiQDMETJnjcg","executionInfo":{"status":"ok","timestamp":1775940067456,"user_tz":180,"elapsed":2626,"user":{"displayName":"FABIO DANIEL SACCONE","userId":"03660020199124133131"}},"outputId":"5ca610af-d8d1-4e4f-e257-b5322fc09422"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Generando núcleos con Poisson Disk...\n","Se generaron 284 núcleos.\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","--- Resultados del ajuste ---\n","n = 1.1667\n","k = 3.3519 (unidades de tiempo^-1.1667192370766997)\n","Ecuación: ln(-ln(1-X)) = 1.1667 * ln(t) + 1.4112\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","--- Comparación con KJMA teórica (nucleación aleatoria) ---\n","n teórico = 2.0\n","k teórico = 1.9415\n","Diferencia relativa en n: 41.66%\n","Diferencia relativa en k: 72.64%\n"]}]}]}